{
  "name": "lockd",
  "version": "0.0.1",
  "description": "Lockd — a browser extension that locks you in. Surgical element-blocking focus tool with work/break sessions.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build:chrome": "cross-env BROWSER=chrome vite build",
    "build:firefox": "cross-env BROWSER=firefox vite build",
    "build": "npm run build:chrome && npm run build:firefox",
    "watch:chrome": "cross-env BROWSER=chrome vite build --watch",
    "watch:firefox": "cross-env BROWSER=firefox vite build --watch",
    "icons": "node scripts/gen-icons.mjs",
    "package": "npm run build && node scripts/package.mjs",
    "lint:firefox": "web-ext lint --source-dir dist/firefox"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.34",
    "cross-env": "^7.0.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
